{
  "name": "project-manager",
  "version": "1.0.0",
  "description": "项目管理桌面软件 - 3D地球版",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"electron .\"",
    "electron:build": "vite build && electron-builder"
  },
  "dependencies": {
    "html2canvas": "^1.4.1",
    "sql.js": "^1.10.3",
    "three": "^0.162.0",
    "vue": "^3.4.21"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.4",
    "concurrently": "^8.2.2",
    "electron": "^29.1.0",
    "electron-builder": "^24.13.3",
    "vite": "^5.1.6"
  },
  "build": {
    "appId": "com.projectmanager.app",
    "productName": "项目管理器",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ]
  }
}
